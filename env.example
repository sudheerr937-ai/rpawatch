# ── AppSignal ────────────────────────────────────────────────────────────────
APPSIGNAL_PUSH_API_KEY=your_push_api_key_here
APPSIGNAL_APP_NAME=RPAWatch

# ── UiPath Mode: "cloud" or "onprem" ─────────────────────────────────────────
UIPATH_MODE=cloud

# ── UiPath Automation Cloud (used when UIPATH_MODE=cloud) ────────────────────
UIPATH_CLIENT_ID=your_client_id
UIPATH_CLIENT_SECRET=your_client_secret
UIPATH_ORGANIZATION=your_org_name
UIPATH_TENANT=your_tenant_name

# ── UiPath On-Premises (used when UIPATH_MODE=onprem) ────────────────────────
# UIPATH_BASE_URL=https://your-orchestrator.company.com
# UIPATH_USERNAME=admin
# UIPATH_PASSWORD=your_password
# UIPATH_TENANCY_NAME=Default

# ── Common ────────────────────────────────────────────────────────────────────
# Orchestrator folder ID (leave blank for Default/root folder)
UIPATH_FOLDER_ID=

# ── Collector behaviour ───────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
LOOKBACK_MINUTES=5
