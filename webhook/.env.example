# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Optional — set a secret and add it to AppSignal webhook config for security
WEBHOOK_SECRET=

# ── UiPath Mode: "cloud" or "onprem" ─────────────────────────────────────────
UIPATH_MODE=cloud

# ── UiPath Automation Cloud ───────────────────────────────────────────────────
UIPATH_CLIENT_ID=your_client_id
UIPATH_CLIENT_SECRET=your_client_secret
UIPATH_ORGANIZATION=your_org_name
UIPATH_TENANT=your_tenant_name

# ── UiPath On-Premises ────────────────────────────────────────────────────────
# UIPATH_BASE_URL=https://your-orchestrator.company.com
# UIPATH_USERNAME=admin
# UIPATH_PASSWORD=your_password
# UIPATH_TENANCY_NAME=Default

# ── Common ────────────────────────────────────────────────────────────────────
UIPATH_FOLDER_ID=

# ── Remediation process names (must match exactly in Orchestrator) ────────────
UIPATH_PROCESS_RESTART=RPAWatch_RestartFaultedJob
UIPATH_PROCESS_REQUEUE=RPAWatch_RequeueFailedItems
UIPATH_PROCESS_ESCALATE=RPAWatch_EscalateToHuman
